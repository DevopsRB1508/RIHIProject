{
  "name": "rlhitechinteriors",
  "version": "1.0.0",
  "description": "Rajalakshmi Hi-Tech Interiors - Unified Application",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "cd client && npm install && npm run build",
    "postinstall": "cd client && npm install",
    "dev:full": "concurrently \"npm run dev\" \"cd client && npm start\""
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "nodemailer": "^6.9.4",
    "twilio": "^4.23.0",
    "body-parser": "^1.20.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}